# Server
PORT=5000
NODE_ENV=development

# Database (Postgres by default; MySQL also supported by swapping the URL scheme)
# Local default (matches README setup instructions):
DATABASE_URL=postgres://chaitanyashah@localhost:5432/backend_intern_db
# Example MySQL:  mysql://user:password@localhost:3306/dbname

# JWT
JWT_SECRET=replace_this_with_a_long_random_secret_string
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=replace_this_with_another_long_random_secret
JWT_REFRESH_EXPIRES_IN=7d

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
